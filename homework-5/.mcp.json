{
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${ACCESS_TOKEN}"
      }
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/Users/s.glushchenko/workspace/AI-workshop/AI-Coding-Partner-Homework"
      ]
    },
    "jira": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/sse"
      ]
    },
    "custom-lorem": {
      "command": "/Users/s.glushchenko/workspace/AI-workshop/AI-Coding-Partner-Homework/.venv/bin/fastmcp",
      "args": [
        "run",
        "/Users/s.glushchenko/workspace/AI-workshop/AI-Coding-Partner-Homework/homework-5/custom-mcp-server/server.py"
      ]
    }
  }
}
